{
  "manifest_version": 3,
  "name": "Stellar Download Manager",
  "version": "0.1.5",
  "description": "Intercepts browser downloads and routes them to the Stellar download manager.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "scripts": ["service-worker.js"]
  },

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png"
    },
    "default_title": "Stellar Download Manager"
  },

  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "contextMenus",
    "tabs",
    "cookies",
    "webRequest",
    "webRequestBlocking"
  ],

  "host_permissions": [
    "<all_urls>"
  ],

  "browser_specific_settings": {
    "gecko": {
      "id": "stellar@stellar.moe",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
