{
  "manifest_version": 3,
  "name": "SDM Integration Module",
  "version": "0.1.6",
  "key": "",
  "description": "Intercepts browser downloads and sends them to the Stellar download manager.",
  "icons": {
    "16":  "icons/milky-way.png",
    "48":  "icons/milky-way.png",
    "128": "icons/milky-way.png"
  },
  "background": {
    "service_worker": "service-worker.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16":  "icons/milky-way.png",
      "48":  "icons/milky-way.png"
    }
  },
  "permissions": [
    "downloads",
    "nativeMessaging",
    "storage",
    "contextMenus",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "web_accessible_resources": [
    {
      "resources": ["page-bridge.js"],
      "matches": ["<all_urls>"]
    }
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ]
}
